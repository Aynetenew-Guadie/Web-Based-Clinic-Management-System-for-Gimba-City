# Backend environment variables (example)
# Copy this file to `.env` and fill in secrets. Do NOT commit `.env`.

# App
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=replace_with_a_secure_secret

# Email (SMTP)
# For Gmail with 2FA, use an App Password for EMAIL_PASS
EMAIL_USER=aynetenew1921@gmail.com
EMAIL_PASS=Ay@1234#

# Optional SMTP host/port/secure overrides (leave blank to use provider inference)
EMAIL_HOST=
EMAIL_PORT=
EMAIL_SECURE=false
EMAIL_FROM=
EMAIL_PROVIDER=
